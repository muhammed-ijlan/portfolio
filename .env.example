# Copy to .env and fill in. Do NOT commit your real .env.

# --- Required ---
# MongoDB connection string (include the database name in the path).
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/portfolio?retryWrites=true&w=majority"
# Long random string for signing admin session cookies, e.g. `openssl rand -base64 48`.
AUTH_SECRET=""
# Default admin, created on first seed/login.
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD=""
# Canonical site URL (used for SEO/OG metadata).
NEXT_PUBLIC_SITE_URL="https://example.com"

# --- Optional ---
# Gate for POST /api/seed. Leave UNSET in production to disable the destructive seed endpoint.
SEED_SECRET=""

# Media uploads (Cloudinary).
CLOUDINARY_URL=""

# Contact-form email (Resend). RESEND_FROM must use a Resend-verified domain.
RESEND_API_KEY=""
RESEND_FROM="Portfolio <noreply@your-verified-domain.com>"
CONTACT_NOTIFY_EMAIL="you@example.com"

# Analytics dashboard (GA4 Data API + Search Console). Base64-encoded service-account JSON.
GOOGLE_SERVICE_ACCOUNT_KEY=""
# Numeric GA4 property id — powers the dashboard traffic charts.
GA4_PROPERTY_ID=""
# Search Console property — powers the dashboard search-performance charts.
GOOGLE_SEARCH_CONSOLE_SITE="sc-domain:example.com"
# GA4 measurement id for the public tracking tag. Rendered in production only.
GA4_MEASUREMENT_ID="G-XXXXXXXXXX"

# Vercel Web Analytics dashboard card. Tracking itself needs no config — it works
# once Web Analytics is enabled for the project. These are only for reading the
# numbers back into /admin.
# Token: Vercel -> Account Settings -> Tokens.
VERCEL_ANALYTICS_TOKEN=""
# Project id: Vercel -> Project -> Settings -> General.
VERCEL_PROJECT_ID=""
# Only for team-owned projects; omit for a personal account.
VERCEL_TEAM_ID=""
