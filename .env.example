# Copy to .env and fill in. Do NOT commit your real .env.

# --- Required ---
# MongoDB connection string (include the database name in the path).
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/portfolio?retryWrites=true&w=majority"
# Long random string for signing admin session cookies, e.g. `openssl rand -base64 48`.
AUTH_SECRET=""
# Default admin, created on first seed/login.
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD=""
# Canonical site URL (used for SEO/OG metadata).
NEXT_PUBLIC_SITE_URL="https://example.com"

# --- Optional ---
# Gate for POST /api/seed. Leave UNSET in production to disable the destructive seed endpoint.
SEED_SECRET=""

# Media uploads (Cloudinary).
CLOUDINARY_URL=""

# Contact-form email (Resend). RESEND_FROM must use a Resend-verified domain.
RESEND_API_KEY=""
RESEND_FROM="Portfolio <noreply@your-verified-domain.com>"
CONTACT_NOTIFY_EMAIL="you@example.com"

# Analytics dashboard (GA4 Data API + Search Console). Base64-encoded service-account JSON.
GOOGLE_SERVICE_ACCOUNT_KEY=""
# Fallback numeric GA4 property id (normally set in admin -> Site Settings).
GA4_PROPERTY_ID=""
